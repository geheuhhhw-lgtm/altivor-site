# ═══════════════════════════════════════════════════════════════
# ALTIVOR Auth API — Konfiguracja
# Skopiuj do .env i uzupełnij wartości
# ═══════════════════════════════════════════════════════════════

# Serwer
PORT=3001
NODE_ENV=development

# Baza danych PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/altivor_auth?schema=public"

# Adres aplikacji frontendowej (do linków w mailach)
APP_URL=http://localhost:8090

# SMTP — wysyłanie emaili
# Opcja 1: Gmail (użyj "Hasło aplikacji" z konta Google)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=twoj.email@gmail.com
SMTP_PASS=haslo_aplikacji_16_znakow

# Opcja 2: SendGrid / Mailgun / własny SMTP
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxx

# Opcja 3: Mailtrap (testowanie)
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=xxx
# SMTP_PASS=xxx

# Od kogo wychodzą emaile
MAIL_FROM_NAME="ALTIVOR INSTITUTE"
MAIL_FROM_EMAIL=noreply@altivor.institute
