# ─── ALTIVOR INSTITUTE — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.

# Session secret (random string, auto-generated if not set)
ALTIVOR_SESSION_SECRET=

# Base URL of the site (used in verification emails)
ALTIVOR_BASE_URL=http://localhost:8090

# ─── SMTP Configuration ──────────────────────────────────────────────────
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your-app-password    (generate at https://myaccount.google.com/apppasswords)
#
# Outlook/Hotmail example:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your@outlook.com
#   SMTP_PASS=your-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# "From" address shown in verification emails
SMTP_FROM=ALTIVOR INSTITUTE <noreply@altivor.institute>
